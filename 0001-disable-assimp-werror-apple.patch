diff --git a/code/CMakeLists.txt b/code/CMakeLists.txt
index e45bf8a..a48a6e7 100644
--- a/code/CMakeLists.txt
+++ b/code/CMakeLists.txt
@@ -1167,6 +1167,10 @@ TARGET_USE_COMMON_OUTPUT_DIRECTORY(assimp)
 # enable warnings as errors ########################################
 IF (MSVC)
   TARGET_COMPILE_OPTIONS(assimp PRIVATE /WX)
+ELSEIF(APPLE AND CMAKE_CXX_COMPILER_ID STREQUAL "AppleClang")
+  # Apple SDK marks some libc functions as deprecated (e.g. vsprintf). Assimp
+  # treats warnings as errors by default; don't do that on AppleClang.
+  # (Keep warnings enabled; just avoid -Werror.)
 ELSE()
   TARGET_COMPILE_OPTIONS(assimp PRIVATE -Werror)
 ENDIF()
@@ -1292,6 +1296,9 @@ ENDIF()
 IF(NOT ASSIMP_HUNTER_ENABLED)
   if (UNZIP_FOUND)
     INCLUDE_DIRECTORIES(${UNZIP_INCLUDE_DIRS})
+    if (UNZIP_LIBRARY_DIRS)
+      set_property(TARGET assimp APPEND PROPERTY LINK_DIRECTORIES "${UNZIP_LIBRARY_DIRS}")
+    endif ()
     TARGET_LINK_LIBRARIES(assimp ${UNZIP_LIBRARIES})
   else ()
     INCLUDE_DIRECTORIES("../")
